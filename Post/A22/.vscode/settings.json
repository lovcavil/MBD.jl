{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "python-envs.pythonProjects": [],
    "actionButtons": {
        "defaultColor": "#ff0034", // Can also use string color names.
        "loadNpmCommands":false, // Disables automatic generation of actions for npm commands.
        "reloadButton":"♻️", // Custom reload button text or icon (default ↻). null value enables automatic reload on configuration change
        "inheritGlobalCommands": false, // In case you use workspace-scope settings, and want to also use User (global) scope settings, you might enable this
        "commands": [
            {
                "cwd": "${workspaceFolder}", 	// Terminal initial folder ${workspaceFolder} and os user home as defaults
                "name": "$(triangle-right)A10",
                "color": "green",
                "singleInstance": true,
                "focus": true,
                "command": "python A10.convert_adams_csv.py" // This is executed in the terminal.
            },
            {
                "cwd": "${workspaceFolder}",
                "name": "$(triangle-right)A20",
                "color": "green",
                "singleInstance": true,
                "focus": true,
                "command": "python A20.compare_expr_sim_performance.py"
            },
            {
                "cwd": "${workspaceFolder}",
                "name": "$(triangle-right)A40",
                "color": "green",
                "singleInstance": true,
                "focus": true,
                "command": "python A40.convert_and_clean_tab.py"
            }
        ]
    }
}
